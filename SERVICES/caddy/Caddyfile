# Node B Caddyfile - All services on 192.168.1.222
# Caddy listens on :80 for Cloudflare-originated traffic
# Cloudflare proxy handles TLS at edge, connects to origin over HTTP

{
    # Global opts
    admin off
}

# ============================================================
# AUTH SERVICE - Authelia's own portal (NO forward_auth loop)
# ============================================================
auth.happystrugglebus.us:80 {
    reverse_proxy localhost:9091
}

# ============================================================
# AUTH-PROTECTED SERVICES - All go through Authelia forward_auth
# ============================================================
media.happystrugglebus.us:80 {
    forward_auth localhost:9091 {
        uri /api/verify?rd=https://{http.request.host}{http.request.uri}
        header_up X-Forwarded-Proto https
        copy_headers Remote-User Remote-Groups Remote-Name Remote-Email

        @302 status 302
        handle_response @302 {
            redir https://auth.happystrugglebus.us/?rd=https://{http.request.host}{http.request.uri}
        }
    }
    reverse_proxy localhost:4343
}

stash.happystrugglebus.us:80 {
    reverse_proxy localhost:9998
}

